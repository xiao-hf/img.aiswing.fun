# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
HOST_PORT=8000
UPSTREAM=http://sub2api:8080
STREAM_UPSTREAM=https://cdn.aiswing.fun
TASK_STREAM_MODE=false
SUB2API_NETWORK=sub2api_default
MAX_BODY_BYTES=62914560

# SQLite async task storage
DATA_DIR=/app/data
SQLITE_PATH=/app/data/aiswing.sqlite
TASK_TTL_HOURS=48
KEY_ENCRYPTION_SECRET=change-this-secret-before-production
WORKER_CONCURRENCY=1
# 0 means do not request upstream preview frames. Set 1-3 only if you need partial image fallback/preview.
UPSTREAM_PARTIAL_IMAGES=0
UPSTREAM_ACCEPT_PARTIAL_FALLBACK=true
TASK_MAX_RETRIES=0
TASK_RETRY_BASE_DELAY_MS=3000
CLEANUP_INTERVAL_MINUTES=10

# If sub2api uses another Docker network, set SUB2API_NETWORK to that network name.
# If a local gateway runs on the Docker host instead, set UPSTREAM to this value manually.
LOCAL_UPSTREAM=http://host.docker.internal:8080

# Optional web one-click update. Set a strong random token before enabling.
UPDATE_TOKEN=
# Default in Docker clones https://github.com/xiao-hf/img.aiswing.fun.git into /app and restarts the process.
# UPDATE_COMMAND=rm -rf /tmp/aiswing-image-studio-update && git clone --depth 1 https://github.com/xiao-hf/img.aiswing.fun.git /tmp/aiswing-image-studio-update && cp -a /tmp/aiswing-image-studio-update/. /app/ && npm install --omit=dev && node --check server.js
UPDATE_RESTART=true
UPDATE_TIMEOUT_MS=600000
